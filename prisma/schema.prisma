generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  pending
  user
  admin
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  schoolNick String  @unique @map("school_nick")
  name      String
  password  String
  role      Role     @default(pending)
  createdAt DateTime @default(now()) @map("created_at")

  characters Character[]
  gallery    Gallery[]
  maps       Map[]
  statuses   Status[]
  rules      Rule[]

  @@map("users")
}

model Campaign {
  id   String @id @default(cuid())
  name String
  slug String @unique

  characters Character[]
  gallery    Gallery[]
  maps       Map[]
  statuses   Status[]
  rules      Rule[]

  @@map("campaigns")
}

model Character {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  campaignId       String   @map("campaign_id")
  name             String
  race             String
  class            String
  level            Int      @default(1)
  background       String   @default("")
  alignment        String   @default("")
  experiencePoints Int      @default(0) @map("experience_points")
  avatarUrl        String   @default("") @map("avatar_url")
  hp               Int
  maxHp            Int      @default(0) @map("max_hp")
  tempHp           Int      @default(0) @map("temp_hp")
  ac               Int      @default(10)
  initiative       Int      @default(0)
  speed            Int      @default(30)
  proficiencyBonus Int      @default(2) @map("proficiency_bonus")
  inspiration      Boolean  @default(false)
  hitDice          String   @default("d10") @map("hit_dice")
  hitDiceTotal     Int      @default(1) @map("hit_dice_total")
  stats            Json     @default("{}")
  sheet            Json     @default("{}")
  equipment        String   @default("")
  notes            String   @default("")
  backstory        String   @default("")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("characters")
}

model Gallery {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  url        String
  caption    String   @default("")
  uploadedBy String   @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [uploadedBy], references: [id])

  @@map("gallery")
}

model Map {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  name       String
  url        String
  uploadedBy String   @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [uploadedBy], references: [id])

  @@map("maps")
}

model Rule {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  title      String
  url        String
  type       String   @default("pdf")
  uploadedBy String   @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [uploadedBy], references: [id])

  @@map("rules")
}

model Status {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  date       DateTime @default(now())
  title      String
  essay      String   @default("")
  result     String   @default("")
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  images StatusImage[]

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [createdBy], references: [id])

  @@map("statuses")
}

model StatusImage {
  id        String   @id @default(cuid())
  statusId  String   @map("status_id")
  url       String
  createdAt DateTime @default(now()) @map("created_at")

  status Status @relation(fields: [statusId], references: [id], onDelete: Cascade)

  @@map("status_images")
}
